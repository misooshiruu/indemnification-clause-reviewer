# Copy this file to .env (or .env.local) and fill in the keys you want to use.
# These are read by the Next.js server only — they are never sent to the browser.
# Restart the dev server after changing them.

# Cloud provider API keys. Set the one(s) for the provider you plan to use; the
# UI will show "key loaded" for any provider that has a key here.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional. Default Ollama endpoint (used if you leave the URL field blank in
# the UI). Only relevant when running the Local (Ollama) backend.
OLLAMA_URL=http://localhost:11434
